# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Env / secrets
.env

# DuckDB working database (rebuilt from ingest + dbt; never committed)
warehouse/*.duckdb
warehouse/*.duckdb.wal

# dbt
transform/target/
transform/dbt_packages/
transform/logs/

# Eval output
eval/report/*.json
eval/report/*.html

# Raw EDGAR companyfacts JSON: large (~25MB), re-fetchable. The small parquet snapshot
# under fixtures/ is committed instead for reproducible offline builds.
fixtures/companyfacts/

# OS
.DS_Store
