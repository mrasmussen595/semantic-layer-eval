# Copy to .env and fill in. .env is gitignored.

# SEC EDGAR requires a descriptive User-Agent identifying who is making requests,
# or it returns 403. Format: "Name email@domain".
SEC_USER_AGENT="Mike Rasmussen mrasmussen595@gmail.com"

# Anthropic API key for the governed analyst agent (Phase 5+). Only needed to run
# the live LLM eval; the deterministic test suite does not require it.
ANTHROPIC_API_KEY=""

# MotherDuck token. Local DuckDB is the default for all development; this is only
# used for the cloud swap-in at the end (Phase 7). Leave blank for local dev.
MOTHERDUCK_TOKEN=""
